{
  "name": "aurea-studio",
  "version": "0.1.0",
  "private": true,
  "description": "AUREA Studio Design System — cinematic, scroll-driven, R3F-powered website engine.",
  "scripts": {
    "dev": "next dev",
    "check:parity": "node --experimental-strip-types scripts/check-parity.mjs",
    "check:prices": "node --experimental-strip-types scripts/check-prices.mjs",
    "check:content": "node scripts/check-content-leaks.mjs",
    "gen:og": "node --experimental-strip-types scripts/gen-og.mjs",
    "audit": "node --experimental-strip-types scripts/audit-phase1.mjs",
    "prebuild": "npm run check:parity && npm run check:prices && npm run check:content && npm run gen:og",
    "check:h1": "node scripts/check-h1.mjs",
    "build": "next build && npm run check:h1",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.13.0",
    "lenis": "^1.1.20",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.171.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.171.0",
    "satori": "^0.28.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5"
  }
}
