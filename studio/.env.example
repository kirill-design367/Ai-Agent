# AUREA — пример .env для СЕРВЕРА (в /opt/aurea/studio/.env).
# Здесь НЕТ секретов. Реальные пароли/ключи/сертификаты — только в GitHub Secrets
# и на сервере (Let's Encrypt), в репозиторий не коммитятся.
#
# Файл .env заполняет либо scripts/deploy-remote.sh (поле IMAGE), либо вы вручную
# при первичной настройке. Скопируйте в .env и при необходимости поправьте.

# Образ приложения.
#   CI/CD-путь: подставляет deploy-remote.sh (ghcr.io/<owner>/aurea-web:<sha>).
#   Fallback (сборка на сервере): оставьте пустым/закомментированным → aurea-web:local.
# IMAGE=ghcr.io/kirill-design367/aurea-web:latest

# Последний рабочий образ — заполняется автоматически для ручного отката.
# PREV_IMAGE=

# Конфиг nginx: http (проверка по IP, до SSL) → https (после выпуска сертификата).
#   Проверка по IP:  ./deploy/nginx.http.conf   (значение по умолчанию)
#   После SSL:       ./deploy/nginx.https.conf
NGINX_CONF=./deploy/nginx.http.conf

# Базовые образы nginx/certbot по умолчанию берутся из GHCR-зеркала (сервер в РФ
# ловит 429 от docker.io). Обычно менять НЕ нужно. Аварийный откат на docker.io:
# NGINX_IMAGE=nginx:1.27-alpine
# CERTBOT_IMAGE=certbot/certbot
