# ── Voximplant Management API ────────────────────────────────────────────────
# Берётся в панели Voximplant: Settings -> API access / Service accounts.
VOX_ACCOUNT_ID=
VOX_API_KEY=
# ID правила (Rule), которое привязано к приложению и сценарию scenario.js.
# Создаётся в Applications -> ваше приложение -> Routing/Rules.
VOX_RULE_ID=

# ── Параметры звонка ─────────────────────────────────────────────────────────
# Ваш купленный/подтверждённый в Voximplant номер (Caller ID).
VOX_CALLER_ID=

# Что говорить абоненту — ДВА режима, выберите один:
#
# Режим A (для теста, ничего хостить не надо): текст для озвучки (TTS).
# Если MESSAGE_TEXT заполнен — робот проговорит его, AUDIO_URL игнорируется.
# Числа лучше писать словами ("один", "сорок"). Оставьте пустым, чтобы
# использовался текст по умолчанию из scenario.js.
MESSAGE_TEXT=
#
# Режим B (боевой, свой голос): прямая ссылка на mp3/wav (НЕ страница Яндекс.Диска,
# а именно прямая ссылка на файл). Чтобы включить — оставьте MESSAGE_TEXT пустым.
# В конце записи должна звучать фраза "...если вам интересно, нажмите 1".
AUDIO_URL=

# ── Telegram ─────────────────────────────────────────────────────────────────
# Токен бота от @BotFather.
TELEGRAM_BOT_TOKEN=
# Куда слать лиды: ваш numeric id (узнать у @userinfobot) или id группы/канала.
TELEGRAM_CHAT_ID=

# ── Прочее ───────────────────────────────────────────────────────────────────
# Пауза между запусками звонков в секундах (чтобы не звонить слишком быстро).
DELAY_BETWEEN_CALLS=6
